{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learnly.local/schemas/swd392-course.schema.json",
  "title": "SWD392 Brilliant-style course manifest",
  "type": "object",
  "required": ["schemaVersion", "source", "course"],
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "schemaVersion": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"},
    "source": {
      "type": "object",
      "required": ["repository", "branch", "commit", "slideDecks", "slidePages", "caseStudyPdfPages"],
      "properties": {
        "repository": {"type": "string", "format": "uri"},
        "branch": {"type": "string", "minLength": 1},
        "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "slideDecks": {"type": "integer", "minimum": 1},
        "slidePages": {"type": "integer", "minimum": 1},
        "caseStudyPdfPages": {"type": "integer", "minimum": 1}
      },
      "additionalProperties": false
    },
    "course": {
      "type": "object",
      "required": ["id", "title", "language", "estimatedMinutes", "levelCount", "lessonCount", "masteryRules", "levels"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "title": {"type": "string", "minLength": 1},
        "subtitle": {"type": "string"},
        "language": {"type": "string", "minLength": 2},
        "technicalVocabulary": {"type": "string"},
        "level": {"enum": ["beginner", "beginner-to-intermediate", "intermediate", "advanced"]},
        "estimatedMinutes": {"type": "integer", "minimum": 1},
        "levelCount": {"type": "integer", "minimum": 1},
        "lessonCount": {"type": "integer", "minimum": 1},
        "targetExercises": {"type": "integer", "minimum": 1},
        "primaryCaseStudy": {"type": "string"},
        "prerequisites": {"type": "array", "items": {"type": "string"}},
        "masteryRules": {
          "type": "object",
          "required": ["lessonPercent", "levelReviewPercent", "capstonePercent"],
          "properties": {
            "lessonPercent": {"type": "integer", "minimum": 0, "maximum": 100},
            "levelReviewPercent": {"type": "integer", "minimum": 0, "maximum": 100},
            "capstonePercent": {"type": "integer", "minimum": 0, "maximum": 100}
          },
          "additionalProperties": false
        },
        "levels": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/level"}
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "level": {
      "type": "object",
      "required": ["id", "title", "outcome", "sourceRefs", "lessons"],
      "properties": {
        "id": {"type": "string", "pattern": "^L[0-9]{2}$"},
        "title": {"type": "string", "minLength": 1},
        "outcome": {"type": "string", "minLength": 1},
        "sourceRefs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "lessons": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/lesson"}}
      },
      "additionalProperties": false
    },
    "lesson": {
      "type": "object",
      "required": ["id", "type", "title", "minutes", "xp", "interactionTypes", "misconceptionTags"],
      "properties": {
        "id": {"type": "string", "pattern": "^L[0-9]{2}-[0-9]{2}$"},
        "type": {"enum": ["concept", "apply", "review", "case-study", "capstone"]},
        "title": {"type": "string", "minLength": 1},
        "minutes": {"type": "integer", "minimum": 1},
        "xp": {"type": "integer", "minimum": 0},
        "interactionTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["choice", "multi", "truefalse", "fill", "order", "match", "visual", "scenario"]}
        },
        "misconceptionTags": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      },
      "additionalProperties": false
    }
  }
}
