  "title": "FOS — Từ brief đến Class Diagram",
  "brief": [
    "Một khách hàng có thể đặt nhiều đơn hàng theo thời gian.",
    "Mỗi đơn hàng gồm các sản phẩm trong catalog; số lượng và đơn giá tại lúc mua chỉ có nghĩa trong từng lần sản phẩm xuất hiện trong đơn.",
    "Mỗi sản phẩm có tên và giá catalog riêng.",
    "Khách hàng có thể lưu một địa chỉ giao hàng thuộc vòng đời hồ sơ khách hàng."
  ],
  "palette": [
    { "label": "Customer", "kind": "class" },
    { "label": "Order", "kind": "class" },
    { "label": "Product", "kind": "class" },
    { "label": "ShippingAddress", "kind": "class" },
    { "label": "name", "kind": "attribute", "targetClassKey": "Customer" },
    { "label": "orderDate", "kind": "attribute", "targetClassKey": "Order" },
    { "label": "productName", "kind": "attribute", "targetClassKey": "Product" },
    { "label": "price", "kind": "attribute", "targetClassKey": "Product" },
    { "label": "street", "kind": "attribute", "targetClassKey": "ShippingAddress" },
    { "label": "city", "kind": "attribute", "targetClassKey": "ShippingAddress" },
