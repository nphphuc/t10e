      { "key": "Order", "name": { "canonical": "Order", "accepted": ["order", "đơn hàng", "donhang", "orders"] }, "requirement": "required", "attributes": [{ "name": { "canonical": "orderDate", "accepted": ["date", "ngày đặt"] }, "requirement": "required" }] },
      { "key": "Product", "name": { "canonical": "Product", "accepted": ["product", "sản phẩm", "sanpham", "products"] }, "requirement": "required", "attributes": [
        { "name": { "canonical": "productName", "accepted": ["name", "tên sản phẩm"] }, "requirement": "required" },
        { "name": { "canonical": "price", "accepted": ["catalogPrice", "giá"] }, "requirement": "required" },
        { "name": { "canonical": "quantity", "accepted": ["số lượng"] }, "requirement": "forbidden", "forbiddenTag": "relationship-data", "forbiddenReason": "quantity thay đổi theo từng giao dịch, không phải thuộc tính cố định của Product." },
        { "name": { "canonical": "priceAtPurchase", "accepted": ["unitPrice", "giá lúc mua"] }, "requirement": "forbidden", "forbiddenTag": "relationship-data", "forbiddenReason": "Giá tại lúc mua thuộc dòng giao dịch, không phải giá catalog cố định của Product." }
      ] },
      { "key": "ShippingAddress", "name": { "canonical": "ShippingAddress", "accepted": ["shipping address", "địa chỉ giao hàng"] }, "requirement": "required", "attributes": [
