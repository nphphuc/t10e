        { "name": { "canonical": "city", "accepted": ["thành phố"] }, "requirement": "required" }
      ] },
      { "key": "OrderLine", "name": { "canonical": "OrderLine", "accepted": ["order item", "orderitem", "dòng đơn hàng"] }, "requirement": "required", "attributes": [
        { "name": { "canonical": "quantity", "accepted": ["số lượng"] }, "requirement": "required" },
        { "name": { "canonical": "priceAtPurchase", "accepted": ["unitPrice", "giá lúc mua"] }, "requirement": "required" }
      ] }
    ],
    "edges": [
