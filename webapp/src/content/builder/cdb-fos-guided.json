    { "label": "priceAtPurchase", "kind": "attribute", "targetClassKey": "OrderLine" },
    { "label": "Đặt hàng", "kind": "verb-trap", "trapTag": "class-is-object", "trapMessage": "'Đặt hàng' là hành vi; hãy dùng làm tên association thay vì class." }
  ],
  "steps": ["find-classes", "place-attributes", "draw-associations", "set-multiplicity", "choose-edge-types", "association-class", "compare"],
  "target": {
    "classes": [
