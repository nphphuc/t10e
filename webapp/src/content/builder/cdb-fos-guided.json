      { "fromKey": "Customer", "toKey": "ShippingAddress", "type": "composition", "multiplicity": { "from": "1", "to": "0..1" }, "requirement": "required", "wrongTypeTag": "aggregation-equals-composition", "reason": "ShippingAddress sống và mất cùng hồ sơ Customer; hãy dùng composition với diamond ở phía Customer." }
    ]
  },
