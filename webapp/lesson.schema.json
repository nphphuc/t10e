{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learnly.local/schemas/swd392-lesson.schema.json",
  "title": "SWD392 Lesson Schema",
  "type": "object",
  "required": ["id", "title", "minutes", "xp", "objective", "misconceptions", "screens"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^L[0-9]{2}-[0-9]{2}$"},
    "title": {"type": "string", "minLength": 1},
    "minutes": {"type": "integer", "minimum": 1},
    "xp": {"type": "integer", "minimum": 1},
    "status": {"type": "string"},
    "needsReview": {"type": "boolean"},
    "sourceRefs": {
      "type": "array",
      "items": {"type": "string"}
    },
    "objective": {"type": "string", "minLength": 1},
    "misconceptions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string"}
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "role", "type"],
        "if": {
          "properties": {"type": {"const": "takeaway"}}
        },
        "then": {
          "required": ["id", "role", "type", "text"]
        },
        "else": {
          "required": ["id", "role", "type", "prompt"]
        },
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "role": {"enum": ["hook", "explore", "feedback", "contrast", "apply", "transfer", "retrieve", "takeaway"]},
          "type": {"enum": ["choice", "multi", "truefalse", "fill", "order", "match", "visual", "scenario", "takeaway"]},
          "prompt": {"type": "string"},
          "options": {
            "type": "array",
            "items": {"type": "string"}
          },
          "correct": {
            "type": ["integer", "boolean", "string"]
          },
          "correctSet": {
            "type": "array",
            "items": {"type": "integer"}
          },
          "correctOrder": {
            "type": "array",
            "items": {"type": "string"}
          },
          "pairs": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "accepted": {
            "type": "array",
            "items": {"type": "string"}
          },
          "visual": {
            "type": "object",
            "required": ["variant"],
            "properties": {
              "variant": {"type": "string"},
              "items": {
                "type": "array",
                "items": {"type": "string"}
              },
              "correctOutside": {
                "type": "array",
                "items": {"type": "string"}
              }
            },
            "additionalProperties": true
          },
          "hints": {
            "type": "array",
            "items": {"type": "string"}
          },
          "solution": {"type": "string"},
          "feedbackCorrect": {"type": "string"},
          "feedbackWrongByItem": {
            "type": "object",
            "additionalProperties": {"type": "string"}
          },
          "explanation": {"type": "string"},
          "consequence": {"type": "string"},
          "distractorTags": {
            "type": "object",
            "additionalProperties": {
              "type": ["string", "null"]
            }
          },
          "weight": {"type": "integer", "minimum": 1},
          "text": {"type": "string"},
          "exitTicket": {"type": "string"}
        }
      }
    }
  }
}
